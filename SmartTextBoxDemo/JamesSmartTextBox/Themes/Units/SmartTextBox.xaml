<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:units="clr-namespace:JamesSmartTextBox.UI.Units">

    <Style TargetType="{x:Type units:SmartTextBox}">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="11,5,11,6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#E5E5E5" />
        <Setter Property="Background" Value="#F5F5F5" />
        <Setter Property="Foreground" Value="#1A1A1A" />
        <Setter Property="CaretBrush" Value="#1A1A1A" />
        <Setter Property="SelectionBrush" Value="#660078D4" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type units:SmartTextBox}">
                    <StackPanel>
                        <TextBlock x:Name="HeaderText"
                                   Text="{TemplateBinding Header}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A1A"
                                   Margin="1,0,0,4"
                                   Visibility="Visible" />
                        <Border x:Name="OuterBorder"
                                MinHeight="{TemplateBinding MinHeight}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="BackgroundBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="{TemplateBinding CornerRadius}"
                                        SnapsToDevicePixels="True" />
                                <Border x:Name="BottomAccent"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="#9E9E9E"
                                        CornerRadius="{TemplateBinding CornerRadius}"
                                        SnapsToDevicePixels="True" />
                                <Grid Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Focusable="False"
                                                  Margin="0"
                                                  Padding="0"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Hidden" />
                                    <TextBlock x:Name="PlaceholderText"
                                               Text="{TemplateBinding Placeholder}"
                                               Foreground="#9E9E9E"
                                               IsHitTestVisible="False"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="ErrorText"
                                   Text="{TemplateBinding ErrorMessage}"
                                   Foreground="#C42B1C"
                                   FontSize="11"
                                   Margin="1,4,0,0"
                                   Visibility="Collapsed" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Header.Length, RelativeSource={RelativeSource Self}, FallbackValue=0, TargetNullValue=0}" Value="0">
                            <Setter TargetName="HeaderText" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsFocused" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#EBEBEB" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#FFFFFF" />
                            <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="#E0E0E0" />
                            <Setter TargetName="BottomAccent" Property="BorderThickness" Value="0,0,0,2" />
                            <Setter TargetName="BottomAccent" Property="BorderBrush" Value="#0078D4" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#F0F0F0" />
                            <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="#E0E0E0" />
                            <Setter TargetName="BottomAccent" Property="BorderBrush" Value="Transparent" />
                            <Setter Property="Foreground" Value="#9E9E9E" />
                        </Trigger>
                        <Trigger Property="IsValid" Value="False">
                            <Setter TargetName="BottomAccent" Property="BorderThickness" Value="0,0,0,2" />
                            <Setter TargetName="BottomAccent" Property="BorderBrush" Value="#C42B1C" />
                            <Setter TargetName="ErrorText" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
