<UserControl x:Class="Tests.Controls.ControlsShowcase.CheckBoxShowcase"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tests.Controls.ControlsShowcase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance local:CheckBoxShowcaseViewModel}"
             d:DesignHeight="600" d:DesignWidth="800"
             mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="24">
            <!--  标题  -->
            <TextBlock FontSize="20" FontWeight="Bold" Text="CheckBox Styles" />
            <TextBlock Margin="0,12,0,0" FontSize="14" Foreground="{DynamicResource ForegroundLeadColor}"
                       Text="参考 shad-ui CheckBox 组件实现的 WPF 隐式样式，支持选中、不确定和禁用三种状态。" />

            <!--  基础用法  -->
            <Border Margin="0,24,0,0" Padding="16" Background="{DynamicResource SelectionColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="基础用法" />
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLeadColor}" Text="默认选中、未选中状态。" />
                    <CheckBox Margin="0,12,0,0" Content="Accept terms and conditions" IsChecked="True" />
                    <CheckBox Margin="0,8,0,0" Content="Accept terms and conditions" />
                </StackPanel>
            </Border>

            <!--  不确定状态  -->
            <Border Margin="0,24,0,0" Padding="16" Background="{DynamicResource SelectionColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="不确定状态" />
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLeadColor}" Text="IsChecked 设为 null 时显示减号图标。" />
                    <CheckBox Margin="0,12,0,0" Content="Select all items" IsChecked="{x:Null}" />
                </StackPanel>
            </Border>

            <!--  禁用状态  -->
            <Border Margin="0,24,0,0" Padding="16" Background="{DynamicResource SelectionColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="禁用状态" />
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLeadColor}" Text="禁用时整体半透明，不可交互。" />
                    <CheckBox Margin="0,12,0,0" Content="Disabled unchecked" IsEnabled="False" />
                    <CheckBox Margin="0,8,0,0" Content="Disabled checked" IsChecked="True" IsEnabled="False" />
                    <CheckBox Margin="0,8,0,0" Content="Disabled indeterminate" IsChecked="{x:Null}" IsEnabled="False" />
                </StackPanel>
            </Border>

            <!--  动态切换演示  -->
            <Border Margin="0,24,0,0" Padding="16" Background="{DynamicResource SelectionColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="动态切换" />
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLeadColor}" Text="通过 ViewModel 控制 CheckBox 的选中与禁用状态。" />
                    <CheckBox Margin="0,12,0,0" Content="Toggle me" IsChecked="{Binding IsChecked}" />
                    <CheckBox Margin="0,8,0,0" Content="I can be disabled" IsChecked="{Binding IsChecked2}" IsEnabled="{Binding CanToggle}" />
                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                        <CheckBox Content="Enable second checkbox" IsChecked="{Binding CanToggle}" />
                    </StackPanel>
                    <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource ForegroundLeadColor}">
                        <Run Text="IsChecked = " /><Run Text="{Binding IsChecked, Mode=OneWay}" />
                        <Run Text="  |  IsChecked2 = " /><Run Text="{Binding IsChecked2, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>