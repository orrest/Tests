<UserControl
    x:Class="Tests.Wpf.Button.ButtonView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tests.Wpf.Button"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance local:ButtonViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="24">
            <TextBlock
                FontSize="20"
                FontWeight="Bold"
                Text="Button Styles" />

            <TextBlock
                Margin="0,12,0,0"
                FontSize="14"
                Text="All button styles defined in Orrest.Controls. Toggle the enabled state to verify the disabled appearance." />

            <!--  Enable / Disable toggle  -->
            <CheckBox
                Margin="0,16,0,0"
                Content="Buttons enabled"
                IsChecked="{Binding Path=ButtonsEnabled}" />

            <!--  ── Primary (default) ─────────────────────────────────────  -->
            <Border
                Margin="0,24,0,0"
                Padding="16"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Primary (default implicit style)" />

                    <StackPanel
                        Margin="0,12,0,0"
                        Orientation="Horizontal">
                        <Button
                            Content="Primary"
                            IsEnabled="{Binding Path=ButtonsEnabled}" />
                        <Button
                            Margin="12,0,0,0"
                            Content="Disabled"
                            IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ── Secondary ─────────────────────────────────────────────  -->
            <Border
                Margin="0,16,0,0"
                Padding="16"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Secondary" />

                    <StackPanel
                        Margin="0,12,0,0"
                        Orientation="Horizontal">
                        <Button
                            Content="Secondary"
                            IsEnabled="{Binding Path=ButtonsEnabled}"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                        <Button
                            Margin="12,0,0,0"
                            Content="Disabled"
                            IsEnabled="False"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ── Destructive ───────────────────────────────────────────  -->
            <Border
                Margin="0,16,0,0"
                Padding="16"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Destructive" />

                    <StackPanel
                        Margin="0,12,0,0"
                        Orientation="Horizontal">
                        <Button
                            Content="Delete"
                            IsEnabled="{Binding Path=ButtonsEnabled}"
                            Style="{DynamicResource DestructiveButtonStyle}" />
                        <Button
                            Margin="12,0,0,0"
                            Content="Disabled"
                            IsEnabled="False"
                            Style="{DynamicResource DestructiveButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ── Ghost ─────────────────────────────────────────────────  -->
            <Border
                Margin="0,16,0,0"
                Padding="16"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Ghost" />

                    <StackPanel
                        Margin="0,12,0,0"
                        Orientation="Horizontal">
                        <Button
                            Content="Ghost"
                            IsEnabled="{Binding Path=ButtonsEnabled}"
                            Style="{DynamicResource GhostButtonStyle}" />
                        <Button
                            Margin="12,0,0,0"
                            Content="Disabled"
                            IsEnabled="False"
                            Style="{DynamicResource GhostButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ── Outline ───────────────────────────────────────────────  -->
            <Border
                Margin="0,16,0,0"
                Padding="16"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Outline" />

                    <StackPanel
                        Margin="0,12,0,0"
                        Orientation="Horizontal">
                        <Button
                            Content="Outline"
                            IsEnabled="{Binding Path=ButtonsEnabled}"
                            Style="{DynamicResource OutlineButtonStyle}" />
                        <Button
                            Margin="12,0,0,0"
                            Content="Disabled"
                            IsEnabled="False"
                            Style="{DynamicResource OutlineButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
