<UserControl x:Class="Tests.Wpf.ControlsShowcase.TextBoxShowcase"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tests.Wpf.ControlsShowcase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance local:TextBoxShowcaseViewModel}"
             d:DesignHeight="600" d:DesignWidth="800"
             mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="24">
            <!--  标题  -->
            <TextBlock FontSize="20" FontWeight="Bold" Text="TextBox Styles" />
            <TextBlock Margin="0,12,0,0" FontSize="14" Foreground="{DynamicResource ForegroundLeadColor}"
                       Text="参考 shad-ui TextBox 组件实现的 WPF 隐式样式，支持基础输入、禁用、多行和验证状态。" />

            <!--  基础用法  -->
            <Border Margin="0,24,0,0" Padding="16" Background="{DynamicResource SelectionColor}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="基础用法" />
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLeadColor}"
                               Text="普通 TextBox 和带初始文字的 TextBox。" />
                    <TextBox Margin="0,12,0,0" Width="300" HorizontalAlignment="Left" />
                    <TextBox Margin="0,8,0,0" Width="300" HorizontalAlignment="Left"
                             Text="{Binding InitialText}" />
                </StackPanel>
            </Border>

            <!--  禁用状态  -->
            <Border Margin="0,24,0,0" Padding="16" Background="{DynamicResource SelectionColor}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="禁用状态" />
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLeadColor}"
                               Text="禁用时整体半透明，不可交互。" />
                    <TextBox Margin="0,12,0,0" Width="300" HorizontalAlignment="Left"
                             Text="Disabled empty" IsEnabled="False" />
                    <TextBox Margin="0,8,0,0" Width="300" HorizontalAlignment="Left"
                             Text="Disabled with text" IsEnabled="False" />
                </StackPanel>
            </Border>

            <!--  多行文本  -->
            <Border Margin="0,24,0,0" Padding="16" Background="{DynamicResource SelectionColor}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="多行文本" />
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLeadColor}"
                               Text="AcceptsReturn=True 的多行输入 TextBox。" />
                    <TextBox Margin="0,12,0,0" Width="300" HorizontalAlignment="Left"
                             Height="120" AcceptsReturn="True"
                             Text="{Binding MultiLineText}" />
                </StackPanel>
            </Border>

            <!--  动态绑定  -->
            <Border Margin="0,24,0,0" Padding="16" Background="{DynamicResource SelectionColor}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="动态绑定" />
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLeadColor}"
                               Text="通过 ViewModel 控制 TextBox 内容，实时显示输入结果。" />
                    <TextBox Margin="0,12,0,0" Width="300" HorizontalAlignment="Left"
                             Text="{Binding BoundText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource ForegroundLeadColor}">
                        <Run Text="当前输入: " /><Run Text="{Binding BoundText, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  密码框  -->
            <Border Margin="0,24,0,0" Padding="16" Background="{DynamicResource SelectionColor}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="密码框" />
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource ForegroundLeadColor}"
                               Text="PasswordBox 使用相同的圆角和边框风格。" />
                    <PasswordBox Margin="0,12,0,0" Width="300" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
