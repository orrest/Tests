<UserControl
    x:Class="Tests.Wpf.Themes.ThemeSwitcherView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tests.Wpf.Themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="24">
            <TextBlock
                FontSize="20"
                FontWeight="Bold"
                Text="Theme Switcher" />

            <TextBlock
                Margin="0,12,0,0"
                FontSize="14"
                Text="Select a theme mode. The change takes effect immediately." />

            <!--  Theme selection  -->
            <Border
                Margin="0,24,0,0"
                Padding="16"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Theme Mode" />

                    <RadioButton
                        Margin="0,12,0,0"
                        Content="Light"
                        GroupName="ThemeMode"
                        IsChecked="{Binding Path=IsLightSelected}" />

                    <RadioButton
                        Margin="0,8,0,0"
                        Content="Dark"
                        GroupName="ThemeMode"
                        IsChecked="{Binding Path=IsDarkSelected}" />

                    <RadioButton
                        Margin="0,8,0,0"
                        Content="Follow system"
                        GroupName="ThemeMode"
                        IsChecked="{Binding Path=IsSystemSelected}" />
                </StackPanel>
            </Border>

            <!--  Preview panel  -->
            <Border
                Margin="0,24,0,0"
                Padding="16"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Preview" />

                    <StackPanel
                        Margin="0,12,0,0"
                        Orientation="Horizontal">
                        <Button
                            Width="100"
                            Height="32"
                            Content="Button" />
                        <CheckBox
                            Margin="12,0,0,0"
                            Content="CheckBox" />
                        <RadioButton
                            Margin="12,0,0,0"
                            Content="RadioButton" />
                    </StackPanel>

                    <TextBox
                        Width="240"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Left"
                        Text="Text input" />

                    <ProgressBar
                        Width="240"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Left"
                        Value="60" />
                </StackPanel>
            </Border>

            <!--  Current status  -->
            <TextBlock
                Margin="0,12,0,0"
                FontStyle="Italic"
                Text="{Binding Path=CurrentThemeText, StringFormat='Current theme: {0}'}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
