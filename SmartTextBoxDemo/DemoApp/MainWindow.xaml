<Window x:Class="DemoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:smart="clr-namespace:JamesSmartTextBox.UI.Units;assembly=JamesSmartTextBox"
        xmlns:validators="clr-namespace:JamesSmartTextBox.Local.Validators;assembly=JamesSmartTextBox"
        mc:Ignorable="d"
        Title="SmartTextBox Demo" Height="650" Width="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" VerticalAlignment="Center">
            <TextBlock Text="SmartTextBox Examples" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" />

            <smart:SmartTextBox Header="Required Field"
                                Placeholder="Enter your name..."
                                Width="300" HorizontalAlignment="Left" Margin="0,0,0,16">
                <smart:SmartTextBox.Validator>
                    <validators:RequiredValidator />
                </smart:SmartTextBox.Validator>
            </smart:SmartTextBox>

            <smart:SmartTextBox Header="Min Length (5)"
                                Placeholder="At least 5 characters"
                                CornerRadius="10"
                                Width="300" HorizontalAlignment="Left" Margin="0,0,0,16">
                <smart:SmartTextBox.Validator>
                    <validators:MinLengthValidator MinLength="5" Message="Must be at least 5 characters." />
                </smart:SmartTextBox.Validator>
            </smart:SmartTextBox>

            <smart:SmartTextBox Header="Email"
                                Placeholder="user@example.com"
                                Width="300" HorizontalAlignment="Left" Margin="0,0,0,16">
                <smart:SmartTextBox.Validator>
                    <validators:EmailValidator />
                </smart:SmartTextBox.Validator>
            </smart:SmartTextBox>

            <smart:SmartTextBox Header="Password"
                                Placeholder="Min 8 chars, upper + lower + number"
                                Width="300" HorizontalAlignment="Left" Margin="0,0,0,16">
                <smart:SmartTextBox.Validator>
                    <validators:PasswordValidator />
                </smart:SmartTextBox.Validator>
            </smart:SmartTextBox>

            <smart:SmartTextBox Header="URL"
                                Placeholder="https://example.com"
                                Width="300" HorizontalAlignment="Left" Margin="0,0,0,16">
                <smart:SmartTextBox.Validator>
                    <validators:UrlValidator />
                </smart:SmartTextBox.Validator>
            </smart:SmartTextBox>

            <smart:SmartTextBox Header="Passport"
                                Placeholder="e.g. AB1234567"
                                Width="300" HorizontalAlignment="Left" Margin="0,0,0,16">
                <smart:SmartTextBox.Validator>
                    <validators:PassportValidator />
                </smart:SmartTextBox.Validator>
            </smart:SmartTextBox>

            <smart:SmartTextBox Header="Credit Card"
                                Placeholder="Card number"
                                Width="300" HorizontalAlignment="Left" Margin="0,0,0,16">
                <smart:SmartTextBox.Validator>
                    <validators:CreditCardValidator />
                </smart:SmartTextBox.Validator>
            </smart:SmartTextBox>

            <smart:SmartTextBox Placeholder="No validation"
                                Width="300" HorizontalAlignment="Left" Margin="0,0,0,16" />

            <smart:SmartTextBox Placeholder="Disabled input"
                                IsEnabled="False"
                                Width="300" HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</Window>
